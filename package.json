{
  "name": "fgacic",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build && cp -r .next/static .next/standalone/.next/static && cp -r public .next/standalone/public",
    "start": "node .next/standalone/server.js",
    "lint": "next lint",
    "playwright": "playwright test --config=tests/playwright.config.ts",
    "playwright:visual": "playwright test --config=tests/visual.config.ts",
    "docker:build": "podman build -t fgacic:local .",
    "docker:run": "podman run --rm -p 3000:3000 -v fgacic-data:/app/data --name fgacic fgacic:local",
    "docker:stop": "podman rm -f fgacic"
  },
  "browserslist": [
    "Chrome >= 100",
    "Firefox >= 100",
    "Edge >= 100",
    "Safari >= 15.4",
    "iOS >= 15.4"
  ],
  "dependencies": {
    "@react-email/components": "^1.0.12",
    "better-sqlite3": "^12.10.0",
    "jose": "^6.2.3",
    "maplibre-gl": "^5.24.0",
    "motion": "^11.0.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^6.12.3",
    "validator": "^13.15.35"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.0.0",
    "@percy/cli": "^1.30.0",
    "@percy/playwright": "^1.0.6",
    "@playwright/test": "^1.45.0",
    "@react-email/ui": "6.3.2",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/validator": "^13.15.10",
    "critters": "^0.0.25",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.0.0",
    "wait-on": "^8.0.0"
  }
}
